<Window x:Class="HDTextureManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HDTextureManager.Services"
        Title="{Binding [AppTitle], Source={x:Static loc:LocalizationService.Instance}}" 
        Height="720" Width="625"
        MinHeight="600" MinWidth="625"
        Icon="Resources/AppIcon.ico"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Segoe UI">
    
    <Window.Resources>
        <loc:LocalizationConverter x:Key="LocConverter"/>

        <!-- 窗口控制按钮样式 -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <SolidColorBrush x:Key="BgCard" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="AccentGold" Color="#FFF5A623"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#FF4A9EFF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#FF00D084"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FFAAAAAA"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#FF1A1A24"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2A2A34"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FF4A9EFF"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FF00D084"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="VariantButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FF2A2A34"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="VariantButtonSelected" TargetType="Button" BasedOn="{StaticResource VariantButton}">
            <Setter Property="Background" Value="#FF4A9EFF"/>
            <Setter Property="BorderBrush" Value="#FF4A9EFF"/>
        </Style>

        <Style x:Key="VariantButtonInstalled" TargetType="Button" BasedOn="{StaticResource VariantButton}">
            <Setter Property="Background" Value="#FF00D084"/>
            <Setter Property="BorderBrush" Value="#FF00D084"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="DownloadProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="4"/>
            <Setter Property="Foreground" Value="#FF4A9EFF"/>
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <!-- 滚动条样式 -->
        <Style x:Key="CustomScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0" CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1" 
                                       Orientation="Vertical" 
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Width="6"
                                       Margin="4,0,0,0"
                                       Background="Transparent"
                                       Opacity="0.6">
                                <ScrollBar.Resources>
                                    <Style TargetType="Thumb">
                                        <Setter Property="Background" Value="#55FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="3"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ScrollBar.Resources>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Win11 风格加载动画 -->
        <Style x:Key="Win11ProgressRing" TargetType="Grid">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>

        <!-- 设置面板动画 -->
        <Storyboard x:Key="SettingsPanelShowAnimation">
            <DoubleAnimation Storyboard.TargetName="SettingsPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-150" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SettingsPanel" 
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
        
        <Storyboard x:Key="SettingsPanelHideAnimation">
            <DoubleAnimation Storyboard.TargetName="SettingsPanel" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-150" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseIn" Amplitude="0.5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="SettingsPanel" 
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.25"/>
        </Storyboard>
    </Window.Resources>

    <Border Background="#FF0F0F13" BorderThickness="0" CornerRadius="8" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="White" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 加载动画覆盖层 -->
            <Grid x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="5" Background="#CC0F0F13" Visibility="Collapsed" Panel.ZIndex="100">
                <Viewbox Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas Width="60" Height="60" RenderTransformOrigin="0.5,0.5">
                        <Canvas.RenderTransform>
                            <RotateTransform x:Name="LoadingRotate" Angle="0"/>
                        </Canvas.RenderTransform>
                        <Canvas.Triggers>
                            <EventTrigger RoutedEvent="Canvas.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="LoadingRotate" 
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Canvas.Triggers>
                        <!-- 5个圆点组成Win11风格加载动画 -->
                        <Ellipse Canvas.Left="26" Canvas.Top="4" Width="8" Height="8" Fill="#FF4A9EFF" Opacity="1"/>
                        <Ellipse Canvas.Left="45.6" Canvas.Top="12.8" Width="8" Height="8" Fill="#FF4A9EFF" Opacity="0.8"/>
                        <Ellipse Canvas.Left="45.6" Canvas.Top="39.2" Width="8" Height="8" Fill="#FF4A9EFF" Opacity="0.6"/>
                        <Ellipse Canvas.Left="6.4" Canvas.Top="39.2" Width="8" Height="8" Fill="#FF4A9EFF" Opacity="0.4"/>
                        <Ellipse Canvas.Left="6.4" Canvas.Top="12.8" Width="8" Height="8" Fill="#FF4A9EFF" Opacity="0.2"/>
                    </Canvas>
                </Viewbox>
            </Grid>

            <!-- 自定义标题栏 -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="#FF15151A" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 图标和标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0">
                        <Image Source="Resources/AppIcon.ico" Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="{Binding [AppTitle], Source={x:Static loc:LocalizationService.Instance}}" Foreground="#FFDDDDDD" FontSize="12" 
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    
                    <!-- 窗口控制按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="MinimizeButton" Style="{StaticResource WindowControlButton}" Content="━" Click="MinimizeButton_Click"/>
                        <Button x:Name="CloseButton" Style="{StaticResource WindowCloseButton}" Content="✕" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

        <!-- 主标题区 -->
        <Border Grid.Row="1" Background="{StaticResource BgCard}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderColor}">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="⬡" FontSize="28" Margin="0,0,10,0" Foreground="{StaticResource AccentGold}"/>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Project Reforged" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentGold}"/>
                            <TextBlock x:Name="VersionText" Text="v1.0.0" FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Top" Margin="4,2,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding [AppTitle], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="SettingsBtn" Content="⚙" Click="SettingsBtn_Click" Style="{StaticResource ActionButton}" 
                            Width="44" Height="36" FontSize="18" Margin="0,0,8,0" ToolTip="{Binding [Settings_Title], Source={x:Static loc:LocalizationService.Instance}}"/>
                    <Button x:Name="OpenWebBtn" Content="🌐" Click="OpenWebBtn_Click" Style="{StaticResource ActionButton}" 
                            Width="44" Height="36" FontSize="16" Margin="0,0,8,0" ToolTip="Web"/>
                    <Button x:Name="RefreshBtn" Content="↻" Click="RefreshBtn_Click" Style="{StaticResource ActionButton}" 
                            Width="44" Height="36" FontSize="18" Margin="0,0,8,0" ToolTip="Refresh"/>
                    <Button x:Name="LaunchGameBtn" Content="▶" Click="LaunchBtn_Click" Style="{StaticResource SuccessButton}" 
                            Width="44" Height="36" FontSize="16" ToolTip="Launch"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 设置面板（Canvas 覆盖层，不影响模块列表布局） -->
        <Canvas x:Name="SettingsPanelCanvas" Grid.Row="2" Grid.RowSpan="2" Panel.ZIndex="50" 
                Visibility="Collapsed" IsHitTestVisible="False" ClipToBounds="True">
            <Border x:Name="SettingsPanel" 
                    Width="565" Canvas.Left="20" Canvas.Right="20" Canvas.Top="8" Visibility="Visible" Opacity="0"
                    Background="#FF1A1A24" BorderBrush="#44FFFFFF" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform Y="-150"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <TextBlock Grid.Row="0" Text="{Binding [Settings_Title], Source={x:Static loc:LocalizationService.Instance}}" FontWeight="Bold" Margin="0,0,0,8" Foreground="{StaticResource TextSecondary}"/>

                    <!-- 第一行：选择安装目录 -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding [Settings_GamePath], Source={x:Static loc:LocalizationService.Instance}}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                        <TextBox x:Name="PathTextBox" Grid.Column="1" IsReadOnly="True" Background="#11000000" 
                                 BorderBrush="{StaticResource BorderColor}" Padding="6,4" Margin="0,0,8,0" Foreground="White"/>
                        <Button Grid.Column="2" Content="{Binding [Settings_Browse], Source={x:Static loc:LocalizationService.Instance}}" Click="BrowseBtn_Click" Style="{StaticResource ActionButton}" MinHeight="32"/>
                    </Grid>

                    <!-- 第二行：语言 -->
                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding [Settings_Language], Source={x:Static loc:LocalizationService.Instance}}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="LanguageComboBox" Grid.Column="1" Width="100" VerticalAlignment="Center" 
                                  SelectionChanged="LanguageComboBox_SelectionChanged" HorizontalAlignment="Left">
                            <ComboBoxItem Content="中文" Tag="zh-CN" />
                            <ComboBoxItem Content="English" Tag="en" />
                            <ComboBoxItem Content="Español" Tag="es" />
                            <ComboBoxItem Content="Deutsch" Tag="de" />
                            <ComboBoxItem Content="Português" Tag="pt" />
                            <ComboBoxItem Content="Русский" Tag="ru" />
                        </ComboBox>
                    </Grid>

                    <!-- 第三行：4GB 补丁 -->
                    <Grid Grid.Row="3" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- 将硬编码文本改为本地化 -->
                        <TextBlock Grid.Column="0" Text="{Binding [Settings_4GBPatch], Source={x:Static loc:LocalizationService.Instance}}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                        <ToggleButton x:Name="Patch4GBToggle" Grid.Column="1" HorizontalAlignment="Left" 
                                      Checked="Patch4GBToggle_Checked" Unchecked="Patch4GBToggle_Unchecked"
                                      Width="60" Height="28">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="border" Background="#FF2A2A34" BorderBrush="#55FFFFFF" BorderThickness="1" CornerRadius="4">
                                        <TextBlock x:Name="text" Text="OFF" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                   Foreground="#FFAAAAAA" FontSize="11"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#FF00D084"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#FF00D084"/>
                                            <Setter TargetName="text" Property="Text" Value="ON"/>
                                            <Setter TargetName="text" Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </Grid>

                    <!-- 第四行：清除缓存和作者 -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="{Binding [Settings_ClearCache], Source={x:Static loc:LocalizationService.Instance}}" Click="ClearCacheBtn_Click" Style="{StaticResource ActionButton}" 
                                Padding="12,6" MinHeight="32" ToolTip="Clear incomplete downloads"/>
                        <TextBlock Grid.Column="1" Text="{Binding [Settings_Author], Source={x:Static loc:LocalizationService.Instance}}" FontSize="10" Foreground="{StaticResource AccentGold}" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Grid>
            </Border>
        </Canvas>

        <!-- 模块列表 -->
        <ScrollViewer Grid.Row="3" Margin="0,12,0,0" Padding="20,0,0,0" Style="{StaticResource CustomScrollViewer}">
            <StackPanel>
                <TextBlock Text="{Binding [Section_Core], Source={x:Static loc:LocalizationService.Instance}}" FontWeight="Bold" Margin="0,0,0,8" Foreground="{StaticResource TextSecondary}"/>
                <WrapPanel x:Name="CorePanel"/>

                <TextBlock Text="{Binding [Section_Optional], Source={x:Static loc:LocalizationService.Instance}}" FontWeight="Bold" Margin="0,16,0,8" Foreground="{StaticResource TextSecondary}"/>
                <WrapPanel x:Name="OptionalPanel"/>

                <TextBlock Text="{Binding [Section_Audio], Source={x:Static loc:LocalizationService.Instance}}" FontWeight="Bold" Margin="0,16,0,8" Foreground="{StaticResource TextSecondary}"/>
                <WrapPanel x:Name="AudioPanel"/>

                <TextBlock Text="{Binding [Section_Ultra], Source={x:Static loc:LocalizationService.Instance}}" FontWeight="Bold" Margin="0,16,0,8" Foreground="{StaticResource TextSecondary}"/>
                <WrapPanel x:Name="UltraPanel"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 状态栏 -->
        <Border Grid.Row="4" Background="{StaticResource BgCard}" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderColor}" Padding="20,10" CornerRadius="0,0,8,8">
            <TextBlock x:Name="StatusText" Text="{Binding [Status_Ready], Source={x:Static loc:LocalizationService.Instance}}" Foreground="{StaticResource TextSecondary}"/>
        </Border>
    </Grid>
    </Border>
</Window>