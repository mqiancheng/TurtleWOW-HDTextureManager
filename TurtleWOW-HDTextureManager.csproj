  <!-- Release 构建后清理多余的文件，只保留单文件 EXE -->
  <Target Name="CleanupAfterBuild" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <!-- 先等待 Costura 完成嵌入（通过 DependsOnTargets） -->
    <ItemGroup>
      <CleanupFiles Include="$(OutputPath)*.dll" Exclude="$(OutputPath)*.resources.dll" />
      <CleanupFiles Include="$(OutputPath)*.pdb" />
      <CleanupFiles Include="$(OutputPath)*.config" />
      <CleanupFiles Include="$(OutputPath)*.xml" />
    </ItemGroup>
    <Delete Files="@(CleanupFiles)" ContinueOnError="true" />
    <!-- 删除语言资源文件夹（卫星程序集已被 Costura 嵌入） -->
    <RemoveDir Directories="$(OutputPath)en;$(OutputPath)es;$(OutputPath)de;$(OutputPath)pt;$(OutputPath)ru;$(OutputPath)zh-CN" ContinueOnError="true" />
    <Message Text="单文件构建完成。输出: $(OutputPath)$(AssemblyName).exe" Importance="high" />
  </Target>
